msgid "Human presence:"
msgstr "人体存在："

msgid "Enable presence automation"
msgstr "启用人体存在自动化"

msgid "Simulation only (do not control the desktop)"
msgstr "仅模拟（不控制桌面）"

msgid "Presence sensor detected"
msgstr "已检测到人体存在传感器"

msgid "Presence sensor unavailable"
msgstr "人体存在传感器不可用"

msgid "Automatic display power-off is blocked on AMDGPU Wayland after observed display failures."
msgstr "检测到显示故障记录，已在 AMDGPU Wayland 环境中阻止自动关闭显示器。"

msgid "Away behavior"
msgstr "离开时的行为"

msgid "Lock screen automatically"
msgstr "自动锁定屏幕"

msgid "Away confirmation (seconds):"
msgstr "离开确认时间（秒）："

msgid "Input idle time (seconds):"
msgstr "输入空闲时间（秒）："

msgid "Startup grace (seconds):"
msgstr "启动宽限时间（秒）："

msgid "Turn off display after locking"
msgstr "锁屏后关闭显示器"

msgid "Display-off delay (ms):"
msgstr "关闭显示器延时（毫秒）："

msgid "Return behavior"
msgstr "返回时的行为"

msgid "Wake lock screen when presence returns"
msgstr "检测到用户返回时唤醒锁屏界面"

msgid "Also wake screens locked manually"
msgstr "同时唤醒手动锁定的屏幕"

msgid "Return confirmation (ms):"
msgstr "返回确认时间（毫秒）："

msgid "On-screen status"
msgstr "屏幕状态提示"

msgid "Show presence status"
msgstr "显示人体存在状态"

msgid "Status delay (ms):"
msgstr "状态提示延时（毫秒）："

msgid "Minimum interval (seconds):"
msgstr "最短提示间隔（秒）："

msgid "Present message:"
msgstr "用户在场提示："

msgid "Away message:"
msgstr "用户离开提示："

msgid "active"
msgstr "运行中"

msgid "inactive"
msgstr "未运行"

msgid "masked"
msgstr "已屏蔽"

msgid "Sensor service: %1; desktop agent: %2"
msgstr "传感器服务：%1；桌面代理：%2"

msgid "Could not read HPD settings: %1"
msgstr "无法读取 HPD 设置：%1"

msgid "Could not run HPD diagnostics: %1"
msgstr "无法运行 HPD 诊断：%1"

msgid "Could not update the HPD desktop agent: %1"
msgstr "无法更新 HPD 桌面代理：%1"

msgid "Could not save HPD settings: %1"
msgstr "无法保存 HPD 设置：%1"

msgid "Command timed out"
msgstr "命令执行超时"

msgid "Command exited with status %1"
msgstr "命令退出，状态码为 %1"

msgid "Effective mode: %1"
msgstr "有效模式：%1"

msgid "Disabled"
msgstr "已禁用"

msgid "Simulation only"
msgstr "仅模拟"

msgid "Wake only"
msgstr "仅唤醒"

msgid "Lock and wake"
msgstr "锁屏并唤醒"

msgid "Lock only"
msgstr "仅锁屏"

msgid "Wake and on-screen status"
msgstr "唤醒并显示屏幕状态"

msgid "On-screen status only"
msgstr "仅显示屏幕状态"

msgid "Monitor only"
msgstr "仅监测"

msgid "Unavailable"
msgstr "不可用"
